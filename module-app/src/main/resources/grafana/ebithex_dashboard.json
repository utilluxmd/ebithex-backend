{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Source de données Prometheus Ebithex",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat",       "name": "Stat",        "version": "" },
    { "type": "panel", "id": "gauge",      "name": "Gauge",       "version": "" },
    { "type": "panel", "id": "table",      "name": "Table",       "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Ebithex — Tableau de bord opérationnel (paiements, payouts, AML, litiges, settlement)",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100, "title": "── Vue Globale", "type": "row" },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null }, { "color": "red", "value": 0.05 }
        ] },
        "unit": "percentunit"
      } },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 }, "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Taux d'erreur (5m)",
      "targets": [{ "expr": "rate(ebithex_payments_failed_total[5m]) / (rate(ebithex_payments_initiated_total[5m]) + 0.0001)", "legendFormat": "Erreur %", "datasource": "${DS_PROMETHEUS}" }],
      "type": "stat" },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null }, { "color": "yellow", "value": 3 }, { "color": "red", "value": 5 }
        ] },
        "unit": "s"
      } },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 }, "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Latence P99 Opérateur (5m)",
      "targets": [{ "expr": "histogram_quantile(0.99, rate(ebithex_operator_call_duration_seconds_bucket[5m]))", "legendFormat": "P99", "datasource": "${DS_PROMETHEUS}" }],
      "type": "stat" },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 }, "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value" },
      "title": "Débit Paiements (TPS)",
      "targets": [{ "expr": "sum(rate(ebithex_payments_initiated_total[1m]))", "legendFormat": "TPS", "datasource": "${DS_PROMETHEUS}" }],
      "type": "stat" },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "red", "value": null }, { "color": "yellow", "value": 50000 }, { "color": "green", "value": 200000 }
        ] },
        "unit": "currencyXOF"
      } },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 }, "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Float Opérateur Min",
      "targets": [{ "expr": "min(ebithex_operator_float_balance)", "legendFormat": "Float Min", "datasource": "${DS_PROMETHEUS}" }],
      "type": "stat" },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 }
        ] }
      } },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 }, "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Alertes AML Ouvertes",
      "targets": [{ "expr": "sum(increase(ebithex_aml_alerts_created_total[24h]))", "legendFormat": "Alertes AML 24h", "datasource": "${DS_PROMETHEUS}" }],
      "type": "stat" },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 50 }
        ] }
      } },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 }, "id": 6,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Litiges Ouverts (24h)",
      "targets": [{ "expr": "increase(ebithex_disputes_opened_total[24h])", "legendFormat": "Litiges 24h", "datasource": "${DS_PROMETHEUS}" }],
      "type": "stat" },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101, "title": "── Paiements & Payouts", "type": "row" },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 }, "id": 10,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Volume Paiements par Opérateur",
      "targets": [
        { "expr": "sum by(operator)(rate(ebithex_payments_initiated_total[5m]))", "legendFormat": "{{operator}}", "datasource": "${DS_PROMETHEUS}" }
      ],
      "type": "timeseries" },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 }, "id": 11,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Taux de Succès par Opérateur",
      "targets": [
        { "expr": "sum by(operator)(rate(ebithex_payments_success_total[5m])) / sum by(operator)(rate(ebithex_payments_initiated_total[5m]) + 0.0001)", "legendFormat": "{{operator}}", "datasource": "${DS_PROMETHEUS}" }
      ],
      "type": "timeseries" },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 }, "id": 12,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Latence Opérateurs (P50 / P95 / P99)",
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by(le)(rate(ebithex_operator_call_duration_seconds_bucket[5m])))", "legendFormat": "P50", "datasource": "${DS_PROMETHEUS}" },
        { "expr": "histogram_quantile(0.95, sum by(le)(rate(ebithex_operator_call_duration_seconds_bucket[5m])))", "legendFormat": "P95", "datasource": "${DS_PROMETHEUS}" },
        { "expr": "histogram_quantile(0.99, sum by(le)(rate(ebithex_operator_call_duration_seconds_bucket[5m])))", "legendFormat": "P99", "datasource": "${DS_PROMETHEUS}" }
      ],
      "type": "timeseries" },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 102, "title": "── AML & Conformité", "type": "row" },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 }, "id": 20,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Alertes AML par Règle et Sévérité",
      "targets": [
        { "expr": "sum by(rule, severity)(increase(ebithex_aml_alerts_created_total[1h]))", "legendFormat": "{{rule}} ({{severity}})", "datasource": "${DS_PROMETHEUS}" }
      ],
      "type": "timeseries" },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 103, "title": "── Settlement & Finance", "type": "row" },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 }, "id": 30,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Batches de Règlement créés par Opérateur",
      "targets": [
        { "expr": "sum by(operator)(increase(ebithex_settlement_batches_created_total[24h]))", "legendFormat": "{{operator}}", "datasource": "${DS_PROMETHEUS}" }
      ],
      "type": "timeseries" },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "id": 104, "title": "── Infrastructure JVM & DB", "type": "row" },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "unit": "percentunit",
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null }, { "color": "yellow", "value": 0.70 }, { "color": "red", "value": 0.85 }
        ] }
      } },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 41 }, "id": 40,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "JVM Heap Usage",
      "targets": [{ "expr": "jvm_memory_used_bytes{area='heap'} / jvm_memory_max_bytes{area='heap'}", "legendFormat": "Heap %", "datasource": "${DS_PROMETHEUS}" }],
      "type": "gauge" },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "unit": "percentunit",
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null }, { "color": "yellow", "value": 0.70 }, { "color": "red", "value": 0.85 }
        ] }
      } },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 41 }, "id": 41,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "DB Connection Pool",
      "targets": [{ "expr": "hikaricp_connections_active / hikaricp_connections_max", "legendFormat": "Pool %", "datasource": "${DS_PROMETHEUS}" }],
      "type": "gauge" }

  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["ebithex", "payments", "mobile-money", "africa"],
  "templating": {
    "list": [
      { "current": {}, "hide": 0, "includeAll": true, "label": "Opérateur",
        "multi": true, "name": "operator", "options": [],
        "query": "label_values(ebithex_payments_initiated_total, operator)",
        "refresh": 2, "type": "query" }
    ]
  },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Ebithex — Operations Dashboard",
  "uid": "ebithex-ops-v1",
  "version": 1
}